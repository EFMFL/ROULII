{
  "info": {
    "name": "Roulii Backend Local Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health - GET /api/v1/health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/health",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "health"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Body contains service health fields', function () {",
              "  pm.expect(body.status).to.eql('ok');",
              "  pm.expect(body.service).to.eql('roulii-backend');",
              "  pm.expect(body.timestamp).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
